# Supabase (create .env.local and fill these)
# Get values from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Magic link: In Supabase Dashboard → Authentication → URL Configuration, set:
# - Site URL: https://yourdomain.com (or http://localhost:5188 for Wilbur dev)
# - Redirect URLs: https://yourdomain.com/auth/callback, http://localhost:5188/auth/callback

# Wilbur AI (server-side only). Use separate keys so local + prod don't share TPM/RPM.
# OPENAI_API_KEY=sk-...          # used in production (Vercel) and fallback
# OPENAI_API_KEY_LOCAL=sk-...   # optional: use a different key for local dev (recommended)
# WILBUR_OPENAI_CONCURRENCY=2    # optional: set to 1 if logs show RPM exhaustion
