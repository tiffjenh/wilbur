# Supabase (create .env.local and fill these)
# Get values from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Magic link: In Supabase Dashboard → Authentication → URL Configuration, set:
# - Site URL: https://yourdomain.com (or http://localhost:5188 for Wilbur dev)
# - Redirect URLs: https://yourdomain.com/auth/callback, http://localhost:5188/auth/callback

# Wilbur AI explain (server-side only; set in Vercel env or .env for vercel dev)
# OPENAI_API_KEY=sk-...
